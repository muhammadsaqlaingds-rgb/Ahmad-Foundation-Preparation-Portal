# MongoDB
MONGODB_URI=

# Session
# REQUIRED — server will refuse to start if missing.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# WhatsApp group invite or chat link (shown on /user/test for premium access)
# Examples:
#   https://chat.whatsapp.com/YourGroupInviteCode
#   https://wa.me/923001234567
NEXT_PUBLIC_WHATSAPP_GROUP_URL=
