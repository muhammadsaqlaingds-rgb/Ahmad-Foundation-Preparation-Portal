# ──────────────────────────────────────────────
#  Ahmad Foundation — MCQ Portal .gitignore
# ──────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js Build Output ──────────────────────
.next/
out/
build/

# ── Environment Variables (NEVER commit) ──────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ── Testing & Coverage ────────────────────────
coverage/
.nyc_output/
jest-results/

# ── TypeScript ────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Logs ──────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS Files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor & IDE ──────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Vercel ────────────────────────────────────
.vercel/

# ── Misc ──────────────────────────────────────
*.pem
*.key
*.cert
.cache/
tmp/
temp/

# ── MongoDB Memory Server (test binary cache) ─
.mongodb-binaries/
mongodb-memory-server/
